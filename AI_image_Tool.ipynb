      "source": [
        "!pip install diffusers accelerate torch gradio huggingface_hub\n",
        "\n",
        "# 셀 2 - 실행\n",
        "import torch\n",
        "import gradio as gr\n",
        "from diffusers import StableDiffusionPipeline\n",
        "\n",
        "def load_model():\n",
        "    pipe = StableDiffusionPipeline.from_pretrained(\n",
        "        \"Linaqruf/anything-v3-1",\n",
        "        torch_dtype=torch.float16\n",
        "    )\n",
        "    pipe = pipe.to(\"cuda\")\n",
        "    pipe.safety_checker = None\n",
        "    pipe.requires_safety_checker = False\n",
        "    return pipe\n",
        "\n",
        "pipe = load_model()\n",
        "\n",
        "def generate(prompt, negative_prompt, steps):\n",
        "    image = pipe(\n",
        "        prompt,\n",
        "        negative_prompt=negative_prompt,\n",
        "        num_inference_steps=int(steps)\n",
        "    ).images[0]\n",
        "    return image\n",
        "\n",
        "demo = gr.Interface(\n",
        "    fn=generate,\n",
        "    inputs=[\n",
        "        gr.Textbox(label=\"프롬프트\", value=\"1girl, full body, standing, white background, clean lineart, monochrome, anime style\"),\n",
        "        gr.Textbox(label=\"네거티브 프롬프트\", value=\"bad hands, extra fingers, bad feet, extra legs, bad anatomy, cropped, color, sketch, pencil, lowres, blurry\"),\n",
        "        gr.Slider(10, 40, value=25, label=\"생성 단계\"),\n",
        "    ],\n",
        "    outputs=gr.Image(label=\"결과\"),\n",
        "    title=\"AI 이미지 생성기\",\n",
        "    description=\"프롬프트를 입력하면 AI가 이미지를 생성합니다.\"\n",
        ")\n",
        "\n",
        "demo.launch()"
      ]
    }
  ]
}
